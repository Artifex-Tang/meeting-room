# .env.example
# 复制为 .env 后修改：cp .env.example .env
# 注意：.env 不要提交到 git（已在 .gitignore 中）

# ---------- 服务端口 ----------
BACKEND_PORT=8000
MYSQL_PORT=3306
REDIS_PORT=6379

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=meeting
MYSQL_USER=meeting
MYSQL_PASSWORD=change_me_password

# ---------- Redis ----------
REDIS_PASSWORD=change_me_redis_password

# ---------- JWT ----------
# 生成：python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace_with_a_random_string_of_at_least_48_chars
JWT_EXPIRE_HOURS_USER=168          # 小程序端 token 有效期（小时），默认 7 天
JWT_EXPIRE_HOURS_ADMIN=2           # 管理端 token 有效期（小时），默认 2 小时

# ---------- 微信小程序 ----------
# 在 https://mp.weixin.qq.com 获取
WECHAT_APPID=wx_your_appid
WECHAT_SECRET=your_wechat_app_secret
# 开发期可以开 mock，后端不会真正调用 code2session，而是用 code 当作 openid
WECHAT_MOCK=true

# ---------- 初始管理员（仅首次 alembic upgrade 时生效） ----------
# 上线前务必修改；首次登录后系统会强制要求改密码
INIT_ADMIN_USERNAME=admin
INIT_ADMIN_PASSWORD=admin123

# ---------- 订阅消息调度器 ----------
# 多副本部署时只允许一个副本为 true，其它全部 false
# 单机部署保持 true 即可
RUN_SCHEDULER=true

# ---------- 日志 ----------
LOG_LEVEL=INFO

# ---------- 时区 ----------
TZ=Asia/Shanghai
