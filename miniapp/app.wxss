page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
  font-size: 28rpx;
  color: #333;
  background: #f5f5f5;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,.06);
}

.btn-primary {
  background: #1890ff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 0 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  display: inline-block;
  text-align: center;
}

.btn-danger {
  background: #ff4d4f;
  color: #fff;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 0 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  display: inline-block;
  text-align: center;
}

.tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.tag-success { background: #f6ffed; color: #52c41a; border: 1rpx solid #b7eb8f; }
.tag-info    { background: #f5f5f5; color: #999;    border: 1rpx solid #d9d9d9; }
.tag-warning { background: #fffbe6; color: #fa8c16; border: 1rpx solid #ffe58f; }
