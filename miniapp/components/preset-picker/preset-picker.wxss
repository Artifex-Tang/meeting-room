.preset-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.preset-btn {
  flex: 1;
  min-width: 140rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
  text-align: center;
  border: 2rpx solid transparent;
}

.preset-btn.active {
  background: #e6f7ff;
  border-color: #1890ff;
}

.preset-btn.disabled {
  opacity: .4;
  pointer-events: none;
}

.preset-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.preset-btn.active .preset-label { color: #1890ff; }

.preset-time {
  font-size: 22rpx;
  color: #888;
  margin-top: 6rpx;
}
