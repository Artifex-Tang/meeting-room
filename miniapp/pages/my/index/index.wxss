.user-card { display: flex; align-items: center; gap: 24rpx; }
.avatar { width: 100rpx; height: 100rpx; border-radius: 50%; background: #eee; }
.nickname { font-size: 32rpx; font-weight: bold; }
.real-name { font-size: 26rpx; color: #888; margin-top: 8rpx; }

.profile-row { display: flex; justify-content: space-between; font-size: 28rpx; padding: 12rpx 0; }
.label { color: #999; }

.section-title { font-size: 28rpx; font-weight: bold; margin-bottom: 16rpx; }
.name-input {
  border: 2rpx solid #e8e8e8; border-radius: 8rpx;
  padding: 16rpx 20rpx; font-size: 28rpx; margin-bottom: 16rpx;
}
.btn-edit {
  background: #f5f5f5; color: #1890ff; border-radius: 8rpx;
  font-size: 28rpx; margin-top: 16rpx;
}
.btn-save {
  background: #1890ff; color: #fff; border-radius: 8rpx;
  font-size: 28rpx; height: 80rpx; line-height: 80rpx; width: 100%;
}
.btn-save.disabled { opacity: .6; }

.btn-logout {
  background: #fff; color: #ff4d4f; border: 2rpx solid #ff4d4f;
  border-radius: 12rpx; font-size: 30rpx; margin-top: 8rpx;
  height: 88rpx; line-height: 88rpx;
}
