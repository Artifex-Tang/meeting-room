.section-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 16rpx; }

.freq-row { display: flex; gap: 16rpx; margin-bottom: 16rpx; }
.freq-btn {
  flex: 1; text-align: center; padding: 16rpx;
  border-radius: 8rpx; background: #f5f5f5; font-size: 28rpx; color: #666;
}
.freq-btn.active { background: #e6f7ff; color: #1890ff; font-weight: bold; }

.weekday-row { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 8rpx; }
.wd-btn {
  width: 88rpx; height: 88rpx; line-height: 88rpx; text-align: center;
  border-radius: 50%; background: #f5f5f5; font-size: 24rpx; color: #666;
}
.wd-btn.active { background: #1890ff; color: #fff; }

.month-row { display: flex; align-items: center; gap: 12rpx; font-size: 28rpx; }
.picker-val {
  background: #f5f5f5; padding: 8rpx 20rpx; border-radius: 8rpx;
  min-width: 60rpx; text-align: center;
}

.date-row { display: flex; align-items: center; gap: 16rpx; }
.date-pick {
  background: #f5f5f5; padding: 16rpx 20rpx; border-radius: 8rpx;
  font-size: 28rpx; color: #333;
}
.dash { color: #999; font-size: 28rpx; }
.estimate { margin-top: 12rpx; color: #1890ff; font-size: 26rpx; }

.time-row { display: flex; align-items: center; gap: 16rpx; }
.time-pick {
  background: #f5f5f5; padding: 16rpx 24rpx; border-radius: 8rpx;
  font-size: 30rpx; color: #333; font-weight: bold;
}

.title-input {
  border: 2rpx solid #e8e8e8; border-radius: 8rpx;
  padding: 16rpx 20rpx; font-size: 28rpx;
}

.btn-submit {
  width: 100%; background: #1890ff; color: #fff; border-radius: 12rpx;
  font-size: 32rpx; height: 96rpx; line-height: 96rpx;
  margin-top: 8rpx; margin-bottom: 40rpx;
}
