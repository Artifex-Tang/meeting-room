.section-title { font-size: 28rpx; font-weight: bold; color: #333; margin-bottom: 12rpx; }

.mode-switch {
  display: flex;
  gap: 16rpx;
}

.mode-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  font-size: 28rpx;
  color: #666;
}

.mode-btn.active {
  background: #e6f7ff;
  color: #1890ff;
  font-weight: bold;
}

.hint-text { font-size: 24rpx; color: #999; margin-bottom: 12rpx; }

.title-input {
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.btn-submit {
  width: 100%;
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 32rpx;
  height: 96rpx;
  line-height: 96rpx;
  margin-top: 8rpx;
  margin-bottom: 40rpx;
}

.btn-submit.disabled { opacity: .6; }
