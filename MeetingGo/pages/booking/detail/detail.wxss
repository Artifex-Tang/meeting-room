.hint { text-align: center; color: #999; margin-top: 100rpx; }
.row { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.row:last-child { border-bottom: none; }
.label { color: #999; font-size: 26rpx; width: 160rpx; flex-shrink: 0; }
.btn-cancel {
  width: 100%; background: #ff4d4f; color: #fff; border-radius: 12rpx;
  font-size: 30rpx; height: 88rpx; line-height: 88rpx; margin-top: 24rpx;
}
