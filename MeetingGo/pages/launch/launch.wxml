<view class="launch-wrap">
  <view wx:if="{{loading}}" class="center">
    <view class="logo-text">会议室预订</view>
    <view class="hint">正在登录…</view>
  </view>

  <view wx:elif="{{error}}" class="center">
    <view class="error-text">{{error}}</view>
    <button class="btn-retry" bindtap="retry">重试</button>
  </view>

  <view wx:elif="{{showProfileForm}}" class="profile-form card">
    <view class="title">完善资料</view>
    <view class="hint">请输入您的真实姓名，以便他人识别预订人信息</view>
    <input
      class="input"
      placeholder="请输入真实姓名"
      value="{{realName}}"
      bindinput="onRealNameInput"
      maxlength="20"
    />
    <button class="btn-submit" bindtap="submitProfile">完成</button>
  </view>
</view>
