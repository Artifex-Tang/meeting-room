.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 12rpx 20rpx;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-btn {
  background: #1890ff;
  color: #fff;
  font-size: 24rpx;
  padding: 0 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  border-radius: 8rpx;
  margin-left: 16rpx;
}

.hint {
  text-align: center;
  color: #999;
  margin-top: 100rpx;
  font-size: 28rpx;
}

.room-card {
  cursor: pointer;
}

.room-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.room-meta {
  display: flex;
  gap: 24rpx;
  color: #666;
  font-size: 26rpx;
  margin-bottom: 8rpx;
}

.room-facilities {
  color: #888;
  font-size: 24rpx;
}
