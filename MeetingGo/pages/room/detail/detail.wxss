.room-name { font-size: 36rpx; font-weight: bold; margin-bottom: 12rpx; }
.room-meta { color: #666; font-size: 26rpx; margin-bottom: 8rpx; }
.room-fac  { color: #888; font-size: 24rpx; margin-bottom: 8rpx; }
.room-desc { color: #999; font-size: 24rpx; margin-top: 8rpx; }

.section-title { font-size: 28rpx; font-weight: bold; margin-bottom: 16rpx; color: #333; }

.date-pick-btn {
  background: #f5f5f5;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
}

.hint { color: #999; text-align: center; padding: 24rpx; }

.action-row {
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
  padding-bottom: 40rpx;
}

.btn-book {
  flex: 2;
  background: #1890ff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  height: 88rpx;
  line-height: 88rpx;
}

.btn-recurrence {
  flex: 1;
  background: #fff;
  color: #1890ff;
  border: 2rpx solid #1890ff;
  border-radius: 12rpx;
  font-size: 28rpx;
  height: 88rpx;
  line-height: 88rpx;
}
